# Required: Google Gemini API key - https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Sayna server (defaults match a local Sayna dev server using sayna.example.yaml)
SAYNA_URL=http://localhost:3002
SAYNA_API_KEY=secret-key-1234567890
SAYNA_WEBHOOK_SECRET=hook-secret-1234567890

# TTS voice (ElevenLabs voice ID)
ELEVENLABS_VOICE_ID=ZIlrSGI4jZqobxRKprJz

# FastAPI port - must match the host port in sayna.example.yaml hooks[].url
PORT=5002
